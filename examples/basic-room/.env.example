# Conta registrada do bonk.io
# Copie para .env e preencha com valores reais (nunca commite .env)
BONK_USERNAME=
BONK_PASSWORD=

# Blob LZ-String do estado inicial de física do football.
# Obrigatório para partidas de football funcionarem corretamente.
# Consulte os comentários em src/bot.ts para saber como capturar.
BONK_INITIAL_STATE=
