BONK_USERNAME=
BONK_PASSWORD=

# development → logs formatados no terminal (pino-pretty)
# production  → logs JSON puro (adequado para PM2 / stdout piped)
NODE_ENV=development

# Modo de jogo. Valores aceitos: football
BONK_GAMEMODE=football

# Tamanho máximo de cada time (jogadores por lado, sem contar o bot em spec).
# 1 = solo / 1v1, 2 = 2v2. Afeta quantos jogadores são necessários para auto-start.
BONK_MAXTEAMSIZE=2

# Número de rounds por partida.
# BONK_ROUNDS=3

# Blob LZ-String do estado inicial de física do mapa (Initial State).
# Codifica posições de spawn dos bro bodies — sem ele os jogadores não aparecem em campo.
# Como obter: abra uma sala de football no bonk.io com o número correto de jogadores,
# inicie uma partida e execute o comando abaixo com a URL da sala antes de iniciar:
#
#   pnpm --filter bonk-room capture-is https://bonk.io/<id-da-sala>
#
# O blob capturado pode ser colado aqui (sobrescreve o do bonk-room.json para o
# maxTeamSize atual) ou configurado diretamente em bonk-room.json > initialStates.
# Os blobs padrão do mapa football para 1, 2 e 4 jogadores ativos já estão
# embutidos na lib e são usados automaticamente se esta variável não for definida.
# BONK_INITIAL_STATE=
